# Used ONCE on first boot to seed the token into the database.
# After seeding, the token is managed automatically (refreshed every ~50 days via cron).
# Do NOT rely on these env vars at runtime — the app reads the token from PostgreSQL.
trial_ACCESS_TOKEN=
trial_IG_ACCOUNT_ID=

